.log-list {
  padding: 20rpx;
}

.top-p {
  width: 750rpx;
  display: flex;
  justify-content: space-evenly;
}

.input-box {
  padding: 10rpx;
  margin-bottom: 10rpx;
  border: 1px solid #ebedf0;
}

.input {
  color: #333;
  font-size: 14px;
  height: 32px;
  line-height: 32px;
  padding: 0 10px;
  border: 1px solid #999;
  margin-bottom: 6px;
}

.log-item {
  box-sizing: border-box;
  width: 750rpx;
  display: flex;
  padding:10rpx;
  border-bottom: 1px solid #ebedf0;
}

.log-item.active {
  background-color: #B7EB8F;
}


.time {
  flex: 1;
  padding: 0 6rpx;
  text-align: right;
}

.item-span {
  color: #666;
  padding: 0 6rpx;
}

.item-span-w2 {
  width: 220rpx;
}