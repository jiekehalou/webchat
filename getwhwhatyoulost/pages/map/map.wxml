<map class="bg" show-compass="true" bindtap="onMapClick" latitude="{{latitude}}" longitude="{{longitude}}" markers="{{markers}}" polyline="{{polylines}}" />
<view class="des-panel">
  <view>
    <text> {{weatherInfo.city}} {{weatherInfo.district}}</text>
  </view>
  <view>
    <text>{{weatherInfo.infos.weather}} {{weatherInfo.infos.wind_direction}} {{weatherInfo.infos.wind_power}}</text>
  </view>
</view>
<view class="search-wrp" style="padding-top: {{menuRect.bottom + menuRect.height/2}}px;">
  <view class="search">
    <image class="location" src="../../images/pokemon_location.png" />
    <input class="input" model:value="{{searchInput}}" data-field="searchInput" auto-focus placeholder="搜索" />
    <button class="mini-btn" type="warn" size="mini" bindtap="onSearch">搜索</button>
  </view>
</view>
