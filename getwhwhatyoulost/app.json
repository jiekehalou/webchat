{
  "pages": [
    "pages/index/index",
    "pages/logs/logs",
    "pages/map/map"
  ],
  "entryPagePath": "pages/index/index",
  "requiredPrivateInfos": [
    "getLocation",
    "onLocationChange",
    "startLocationUpdateBackground",
    "chooseAddress"
  ],
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于小程序位置接口的效果展示"
    }
  },
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#07C160",
    "navigationBarTitleText": "失物招领处",
    "navigationBarTextStyle": "black",
    "pageOrientation": "auto"
  },
  "networkTimeout": {
    "request": 10000,
    "downloadFile": 10000
  },
  "tabBar": {
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "images/bar/home.png",
        "selectedIconPath": "images/bar/home_select.png"
      },
      {
        "pagePath": "pages/logs/logs",
        "text": "日志",
        "iconPath": "images/bar/log.png",
        "selectedIconPath": "images/bar/log_select.png"
      },
      {
        "pagePath": "pages/map/map",
        "text": "地图",
        "iconPath": "images/bar/map.png",
        "selectedIconPath": "images/bar/map_select.png"
      }
    ]
  },
  "lazyCodeLoading": "requiredComponents",
    "usingComponents": {
      "tms-button": "@tmsfe/tms-ui/button/index",
      "van-button": "@vant/weapp/button/index",
      "van-cell": "@vant/weapp/cell/index"
    }
}